<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--Создадим корневой AnchorPane, который будет с почти прозрачным фоном, но не полностью
что бы компилятор принимал его во внимание, внутри него создадим отступы для содержимого в 13px
что будет равно толщине, где можно изменять размеры окна. Визуально будет казаться, что мы изменяем
размеры окна за самим окном, хотя по факту мы будем находиться в нём-->
<AnchorPane fx:id="rootAnchorPane" style="-fx-background-color: rgba(0,0,0,0.01);" xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.example.speech.AuthorizationWindow">

    <!--Создадим основной AnchorPane, которому дадим фон-изображение и в котором будут находиться
     шапка окна и панель входа-->
    <AnchorPane styleClass="authorization-background" stylesheets="@styles.css" AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <!--Вставим разметку из файла WindowControls.fxml и привяжем её к верху основного AnchorPane
        задав высоту 40px-->
        <fx:include prefHeight="40" source="WindowControls.fxml" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
                    AnchorPane.topAnchor="0"/>

        <!--Форма авторизации - занимает всё оставшееся пространство, содержимое находиться в центре.
        Имеет два столбца и 9 строк-->
        <GridPane alignment="CENTER" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
                  AnchorPane.topAnchor="40">

            <columnConstraints>
                <ColumnConstraints percentWidth="15"/>
                <ColumnConstraints percentWidth="30"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints percentHeight="10"/>
                <RowConstraints percentHeight="5"/>
                <RowConstraints percentHeight="5"/>
                <RowConstraints percentHeight="5"/>
                <RowConstraints percentHeight="5"/>
                <RowConstraints percentHeight="5"/>
                <RowConstraints percentHeight="5"/>
                <RowConstraints percentHeight="5"/>
                <RowConstraints percentHeight="10"/>
            </rowConstraints>

            <!--Создадим Pane, что бы закрашивать не весь Grid, а только зону внутри столбцов и строк-->
            <Pane styleClass="main-pane" GridPane.columnSpan="2" GridPane.rowSpan="9"/>

            <!--Метка со стилем основной информации-->
            <Label styleClass="basic-information" text="С возвращением!" GridPane.columnSpan="2"
                   GridPane.halignment="CENTER" GridPane.valignment="BOTTOM"/>

            <!--Метка со стилем второстепенной информации-->
            <Label styleClass="secondary-information" text="Мы так рады видеть вас снова!" GridPane.columnSpan="2"
                   GridPane.halignment="CENTER" GridPane.rowIndex="1" GridPane.valignment="TOP"/>

            <!--Метка со стилем прочей информации, в коде на java текст и стиль метки могут меняться-->
            <Label fx:id="mailLb" style="-fx-font-weight: bold;" styleClass="other-information" text="E-MAIL"
                   GridPane.columnSpan="2" GridPane.rowIndex="2" GridPane.valignment="BOTTOM">
                <padding>
                    <Insets bottom="4" left="10"/>
                </padding>
            </Label>

            <!--Поле ввода email, стиль так же может меняться в результате работы программы-->
            <TextField fx:id="mailTF" GridPane.columnSpan="2" GridPane.rowIndex="3" GridPane.valignment="TOP"
                styleClass="text-field">
                <GridPane.margin>
                    <Insets bottom="7" left="10" right="10"/>
                </GridPane.margin>
            </TextField>

            <!--Метка со стилем прочей информации, в коде на java текст и стиль метки могут меняться-->
            <Label fx:id="passwordLb" style="-fx-font-weight: bold;" styleClass="other-information" text="ПАРОЛЬ"
                   GridPane.columnSpan="2" GridPane.rowIndex="4" GridPane.valignment="BOTTOM">
                <padding>
                    <Insets bottom="4" left="10"/>
                </padding>
            </Label>

            <!--Поле ввода password, стиль так же может меняться в результате работы программы-->
            <PasswordField fx:id="passwordF" GridPane.columnSpan="2" GridPane.rowIndex="5" GridPane.valignment="TOP"
                styleClass="text-field">
                <GridPane.margin>
                    <Insets bottom="7" left="10" right="10"/>
                </GridPane.margin>
            </PasswordField>

            <!--Кнопка для перехода в окно, где возможно восстановить пароль, стиль текста-->
            <Button fx:id="lostPasswordBtn" onAction="#onLostPasswordBtn" text="Забыли пароль?" GridPane.rowIndex="6"
                    styleClass="link-button" GridPane.columnSpan="2">
                <GridPane.margin>
                    <Insets left="10"/>
                </GridPane.margin>
            </Button>

            <!--Кнопка для перехода на основное окно приложения-->
            <Button fx:id="entranceBtn" onAction="#onEntranceBtn" text="Вход" GridPane.columnSpan="2"
                    GridPane.rowIndex="7" maxWidth="Infinity" styleClass="login-button">
                <GridPane.margin>
                    <Insets left="10" right="10"/>
                </GridPane.margin>
            </Button>

            <!--Метка-подсказка со стилем прочей информации-->
            <Label styleClass="other-information" text="Нужна учётная запись?" GridPane.rowIndex="8">
                <padding>
                    <Insets left="10" right="10"/>
                </padding>
            </Label>

            <!--Кнопка для перехода в окно, где можно зарегистрировать аккаунт, стиль текста-->
            <Button fx:id="registerBtn" onAction="#onRegisterBtn" text="Зарегистрироваться" GridPane.columnIndex="1"
                    GridPane.rowIndex="8" styleClass="link-button">
                <GridPane.margin>
                    <Insets left="10"/>
                </GridPane.margin>
            </Button>

        </GridPane>

    </AnchorPane>

</AnchorPane>
