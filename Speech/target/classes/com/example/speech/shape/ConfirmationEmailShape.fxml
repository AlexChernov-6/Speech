<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" stylesheets="@../styles.css"
            fx:controller="com.example.speech.control.ConfirmationEmailController" styleClass="main-pane">

    <GridPane AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <rowConstraints>
            <RowConstraints percentHeight="20"/>
            <RowConstraints percentHeight="20"/>
            <RowConstraints percentHeight="10"/>
            <RowConstraints vgrow="NEVER" prefHeight="45" maxHeight="45"/>
            <RowConstraints percentHeight="10"/>
            <RowConstraints vgrow="ALWAYS" prefHeight="45" minHeight="45"/>
        </rowConstraints>

        <columnConstraints>
            <ColumnConstraints hgrow="ALWAYS" minWidth="10"/>
            <ColumnConstraints prefWidth="40" hgrow="NEVER" maxWidth="40"/>
        </columnConstraints>


        <Button fx:id="closeBtn" onAction="#onCloseBtn" prefWidth="40" prefHeight="15" style="-fx-border-radius: 12;
        -fx-background-radius: 12;" styleClass="window-control-button, close-button" GridPane.columnIndex="1"
                GridPane.valignment="TOP">
        </Button>

        <Label styleClass="basic-information" text="Подтверждение Email" prefHeight="30" GridPane.valignment="BOTTOM">
            <GridPane.margin>
                <Insets left="15"/>
            </GridPane.margin>
        </Label>

        <Label fx:id="contentLb" styleClass="secondary-information" wrapText="true" GridPane.columnSpan="2"
               GridPane.rowIndex="1" GridPane.valignment="TOP">
            <GridPane.margin>
                <Insets left="15" top="7" bottom="7" right="15"/>
            </GridPane.margin>
        </Label>

        <Label fx:id="informationLb" styleClass="secondary-information" GridPane.columnSpan="2" GridPane.rowIndex="2"
               GridPane.halignment="CENTER">
            <GridPane.margin>
                <Insets left="15" right="15"/>
            </GridPane.margin>
        </Label>

        <HBox GridPane.columnSpan="2" GridPane.rowIndex="3" alignment="CENTER_LEFT">
            <GridPane.margin>
                <Insets left="15" right="15"/>
            </GridPane.margin>

            <TextField fx:id="num1" styleClass="text-field" prefWidth="30" prefHeight="40"/>
            <TextField fx:id="num2" styleClass="text-field" prefWidth="30" prefHeight="40">
                <HBox.margin>
                    <Insets left="10"/>
                </HBox.margin>
            </TextField>
            <TextField fx:id="num3" styleClass="text-field" prefWidth="30" prefHeight="40">
                <HBox.margin>
                    <Insets left="10"/>
                </HBox.margin>
            </TextField>
            <TextField fx:id="num4" styleClass="text-field" prefWidth="30" prefHeight="40">
                <HBox.margin>
                    <Insets left="10"/>
                </HBox.margin>
            </TextField>
            <TextField fx:id="num5" styleClass="text-field" prefWidth="30" prefHeight="40">
                <HBox.margin>
                    <Insets left="10"/>
                </HBox.margin>
            </TextField>
            <TextField fx:id="num6" styleClass="text-field" prefWidth="30" prefHeight="40">
                <HBox.margin>
                    <Insets left="10"/>
                </HBox.margin>
            </TextField>
        </HBox>

        <Button fx:id="getCodeBtn" GridPane.rowIndex="4" GridPane.columnSpan="2" text="Получить код"
                styleClass="link-button" onAction="#onGetCodeBtn">
            <GridPane.margin>
                <Insets left="15" right="15"/>
            </GridPane.margin>
        </Button>

        <Button GridPane.rowIndex="5" GridPane.columnSpan="2" styleClass="login-button" text="Подтвердить">
            <GridPane.margin>
                <Insets left="15" right="15"/>
            </GridPane.margin>
        </Button>
    </GridPane>

</AnchorPane>
