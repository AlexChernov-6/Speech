<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>

<!--Корневой разметкой будет AnchorPane в стиле Pane у GridPane-->
<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" stylesheets="@../styles.css"
            fx:controller="com.example.speech.controls.LostPasswordController" styleClass="main-pane">

    <!--Зададим отступы для содержимого-->
    <padding>
        <Insets left="15" right="15" top="10" bottom="10"/>
    </padding>

    <!--Первый Label привяжем к верху Anchor и зададим ширину в 30px-->
    <Label styleClass="basic-information" text="Инструкции отправлены" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
           AnchorPane.rightAnchor="0" prefHeight="30"/>

    <!--Центральный Label будет содержать информацию о смене пароля-->
    <Label fx:id="contentLb" AnchorPane.topAnchor="50" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
           AnchorPane.bottomAnchor="50" styleClass="secondary-information" wrapText="true"/>

    <!--В правом нижнем углу разместим кнопку закрытия окна информации-->
    <Button AnchorPane.bottomAnchor="0" AnchorPane.rightAnchor="0" prefHeight="30" onAction="#onOkBtn" text="OK"
            styleClass="login-button" prefWidth="100"/>

</AnchorPane>
