<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<GridPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.example.speech.control.WindowControlsController">
    <columnConstraints>
        <ColumnConstraints percentWidth="50"/>
        <ColumnConstraints percentWidth="50"/>
    </columnConstraints>

    <Label prefHeight="50" alignment="TOP_LEFT" text="SPEECH" style="
    -fx-text-fill: #003B14;
    -fx-font-weight: bold;
    -fx-font-size: 20;
    -fx-font-family: 'Arial';
    -fx-effect: dropshadow(gaussian, rgba(88, 101, 242, 0.3), 4, 0.5, 1, 1);
    -fx-padding: 5px 0px 0px 10px;
    "/>

    <HBox GridPane.columnIndex="1" alignment="TOP_RIGHT">
        <Button fx:id="wrapBtn" onAction="#onWrapBtn"/>
        <Button fx:id="expandBtn" onAction="#onExpandBtn"/>
        <Button fx:id="closeBtn" onAction="#onCloseBtn"/>
    </HBox>
</GridPane>
